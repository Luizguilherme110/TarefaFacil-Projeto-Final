# Configurações do Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados (exemplos)
# Para PostgreSQL:
# DATABASE_URL="postgresql://usuario:senha@localhost:5432/tarefafacil?schema=public"
# Para desenvolvimento rápido com SQLite (arquivo local):
DATABASE_URL="file:./dev.db"

# JWT Secret (Gere uma chave segura e única)
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_troque_isso
JWT_EXPIRES_IN=7d

# Configurações de Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_app
EMAIL_FROM=TarefaFácil <noreply@tarefafacil.com>

# URL do Frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# Configurações de Notificações
ENABLE_NOTIFICATIONS=true
NOTIFICATION_HOUR=9
