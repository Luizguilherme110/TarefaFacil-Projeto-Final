// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  role      String   @default("ALUNO")
  resetToken String?
  resetTokenExpiry DateTime?

  notificacoesAtivas Boolean @default(true)
  horarioNotificacao Int     @default(9)

  fotoPerfil     String?
  telefone       String?
  endereco       String?
  biografia      String?

  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  tarefasRecebidas Tarefa[] @relation("TarefasRecebidas")
  tarefasCriadas   Tarefa[] @relation("TarefasCriadas")

  @@map("usuarios")
}

model Tarefa {
  id          Int      @id @default(autoincrement())
  titulo      String
  descricao   String?
  disciplina  String
  prioridade  String
  dataEntrega DateTime
  status      String   @default("PENDENTE")
  valorPontos Float?

  dataConclusao DateTime?
  nota          Float?
  feedbackProfessor String?

  usuarioId Int
  usuario   Usuario @relation("TarefasRecebidas", fields: [usuarioId], references: [id], onDelete: Cascade)

  criadoPorId Int?
  criadoPor   Usuario? @relation("TarefasCriadas", fields: [criadoPorId], references: [id], onDelete: SetNull)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  notificacoes Notificacao[]

  @@index([usuarioId])
  @@index([criadoPorId])
  @@index([dataEntrega])
  @@index([status])
  @@map("tarefas")
}

model Notificacao {
  id         Int      @id @default(autoincrement())
  tipo       String
  enviada    Boolean  @default(false)
  dataEnvio  DateTime?

  tarefaId   Int
  tarefa     Tarefa   @relation(fields: [tarefaId], references: [id], onDelete: Cascade)

  criadoEm   DateTime @default(now())

  @@index([tarefaId])
  @@index([enviada])
  @@map("notificacoes")
}

// Enums removed for SQLite compatibility; fields use String temporarily.
